#!/usr/bin/env python3

import argparse
import os
import shutil
import subprocess
import sys
from datetime import datetime
from pathlib import Path


DB_NAME = "mailserver"
VMAIL_USER = "vmail"
VMAIL_GROUP = "vmail"
VHOSTS_ROOT = Path("/var/mail/vhosts")
EXIM_UPDATE_CONF = Path("/etc/exim4/update-exim4.conf.conf")


def die(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def require_root() -> None:
    if os.geteuid() != 0:
        die("run with sudo or as root")


def sql_quote(value: str) -> str:
    return value.replace("\\", "\\\\").replace("'", "\\'")


def run(cmd: list[str], *, input_text: str | None = None, check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(
        cmd,
        input=input_text,
        text=True,
        capture_output=True,
        check=check,
    )


def mysql(query: str, *, database: str | None = DB_NAME, raw: bool = False) -> str:
    cmd = ["mysql", "--batch", "--skip-column-names", "--raw"]
    if database:
        cmd.append(database)
    cmd.extend(["-e", query])
    proc = run(cmd, check=False)
    if proc.returncode != 0:
        die(proc.stderr.strip() or proc.stdout.strip() or "mysql command failed")
    if raw:
        return proc.stdout
    return proc.stdout.strip()


def mysql_exists(query: str) -> bool:
    return mysql(query) != ""


def hash_password(password: str) -> str:
    proc = run(["doveadm", "pw", "-s", "SHA512-CRYPT", "-p", password], check=False)
    if proc.returncode != 0:
        die(proc.stderr.strip() or "failed to hash password")
    return proc.stdout.strip()


def sync_exim_local_domain(domain: str, *, present: bool) -> None:
    if not EXIM_UPDATE_CONF.exists():
        die(f"missing exim config file: {EXIM_UPDATE_CONF}")

    lines = EXIM_UPDATE_CONF.read_text().splitlines()
    updated: list[str] = []
    changed = False

    for line in lines:
        if not line.startswith("dc_other_hostnames="):
            updated.append(line)
            continue

        prefix, value = line.split("=", 1)
        raw = value.strip()
        if len(raw) < 2 or raw[0] != "'" or raw[-1] != "'":
            die("unexpected dc_other_hostnames format in exim config")

        items = [item.strip() for item in raw[1:-1].split(";") if item.strip()]
        items_lower = [item.lower() for item in items]
        domain = domain.lower()

        if present and domain not in items_lower:
            items.append(domain)
            changed = True
        if not present and domain in items_lower:
            items = [item for item in items if item.lower() != domain]
            changed = True

        updated.append(f"{prefix}='{';'.join(items)}'")

    if changed:
        EXIM_UPDATE_CONF.write_text("\n".join(updated) + "\n")
        run(["update-exim4.conf"], check=True)
        run(["systemctl", "reload", "exim4"], check=True)


def ensure_domain_dir(domain: str) -> Path:
    path = VHOSTS_ROOT / domain
    path.mkdir(mode=0o750, parents=True, exist_ok=True)
    shutil.chown(path, user=VMAIL_USER, group=VMAIL_GROUP)
    os.chmod(path, 0o2750)
    return path


def ensure_maildir(email: str) -> Path:
    local, domain = split_email(email)
    domain_dir = ensure_domain_dir(domain)
    mailbox_root = domain_dir / local
    maildir = mailbox_root / "Maildir"
    for path, mode in (
        (mailbox_root, 0o750),
        (maildir, 0o700),
        (maildir / "cur", 0o700),
        (maildir / "new", 0o700),
        (maildir / "tmp", 0o700),
    ):
        path.mkdir(mode=mode, parents=True, exist_ok=True)
        shutil.chown(path, user=VMAIL_USER, group=VMAIL_GROUP)
        os.chmod(path, mode)
    return mailbox_root


def archive_maildir(email: str) -> None:
    local, domain = split_email(email)
    mailbox_root = VHOSTS_ROOT / domain / local
    if not mailbox_root.exists():
        return
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    target = mailbox_root.with_name(f"{mailbox_root.name}.deleted-{stamp}")
    mailbox_root.rename(target)
    print(f"archived mailbox files to {target}")


def purge_maildir(email: str) -> None:
    local, domain = split_email(email)
    mailbox_root = VHOSTS_ROOT / domain / local
    if mailbox_root.exists():
        shutil.rmtree(mailbox_root)
        print(f"removed mailbox files at {mailbox_root}")


def split_email(email: str) -> tuple[str, str]:
    if "@" not in email or email.count("@") != 1:
        die(f"invalid email address: {email}")
    local, domain = email.split("@", 1)
    if not local or not domain:
        die(f"invalid email address: {email}")
    return local.lower(), domain.lower()


def get_domain_id(domain: str) -> str:
    domain = domain.lower()
    result = mysql(f"SELECT id FROM domains WHERE name='{sql_quote(domain)}'")
    if not result:
        die(f"domain not found: {domain}")
    return result


def get_mailbox_id(email: str) -> str:
    email = email.lower()
    result = mysql(f"SELECT id FROM mailboxes WHERE email='{sql_quote(email)}'")
    if not result:
        die(f"mailbox not found: {email}")
    return result


def cmd_domain_list(_args: argparse.Namespace) -> None:
    rows = mysql("SELECT id, name, active, created_at, updated_at FROM domains ORDER BY name", raw=True)
    print(rows, end="")


def cmd_domain_add(args: argparse.Namespace) -> None:
    domain = args.domain.lower()
    mysql(
        "INSERT INTO domains (name, active) "
        f"VALUES ('{sql_quote(domain)}', 1) "
        "ON DUPLICATE KEY UPDATE active=1, updated_at=CURRENT_TIMESTAMP"
    )
    ensure_domain_dir(domain)
    sync_exim_local_domain(domain, present=True)
    print(f"domain ready: {domain}")


def cmd_domain_del(args: argparse.Namespace) -> None:
    domain = args.domain.lower()
    domain_id = get_domain_id(domain)
    mailbox_count = mysql(f"SELECT COUNT(*) FROM mailboxes WHERE domain_id={domain_id}")
    alias_count = mysql(f"SELECT COUNT(*) FROM aliases WHERE domain_id={domain_id}")
    if mailbox_count != "0" or alias_count != "0":
        die(f"domain {domain} still has {mailbox_count} mailbox(es) and {alias_count} alias(es)")
    mysql(f"DELETE FROM domains WHERE id={domain_id}")
    sync_exim_local_domain(domain, present=False)
    domain_dir = VHOSTS_ROOT / domain
    if args.purge_dir and domain_dir.exists():
        shutil.rmtree(domain_dir)
        print(f"removed directory {domain_dir}")
    print(f"domain removed: {domain}")


def cmd_mailbox_list(args: argparse.Namespace) -> None:
    where = ""
    if args.domain:
        where = f" WHERE d.name='{sql_quote(args.domain.lower())}'"
    query = (
        "SELECT m.id, m.email, m.active, COALESCE(m.quota_bytes, ''), d.name "
        "FROM mailboxes m JOIN domains d ON d.id = m.domain_id"
        f"{where} ORDER BY d.name, m.email"
    )
    print(mysql(query, raw=True), end="")


def cmd_mailbox_add(args: argparse.Namespace) -> None:
    email = args.email.lower()
    local, domain = split_email(email)
    domain_id = get_domain_id(domain)
    password_hash = hash_password(args.password)
    quota_sql = "NULL" if args.quota_bytes is None else str(args.quota_bytes)
    mysql(
        "INSERT INTO mailboxes (domain_id, local_part, email, password, active, quota_bytes) VALUES ("
        f"{domain_id}, '{sql_quote(local)}', '{sql_quote(email)}', '{sql_quote(password_hash)}', 1, {quota_sql}) "
        "ON DUPLICATE KEY UPDATE "
        f"local_part=VALUES(local_part), password=VALUES(password), active=1, quota_bytes={quota_sql}, updated_at=CURRENT_TIMESTAMP"
    )
    mailbox_id = get_mailbox_id(email)
    mysql(
        "INSERT INTO sender_acl (mailbox_id, allowed_email, active) VALUES ("
        f"{mailbox_id}, '{sql_quote(email)}', 1) "
        "ON DUPLICATE KEY UPDATE active=1, updated_at=CURRENT_TIMESTAMP"
    )
    ensure_maildir(email)
    print(f"mailbox ready: {email}")


def cmd_mailbox_passwd(args: argparse.Namespace) -> None:
    email = args.email.lower()
    get_mailbox_id(email)
    password_hash = hash_password(args.password)
    mysql(
        "UPDATE mailboxes "
        f"SET password='{sql_quote(password_hash)}', updated_at=CURRENT_TIMESTAMP "
        f"WHERE email='{sql_quote(email)}'"
    )
    print(f"password updated: {email}")


def cmd_mailbox_update(args: argparse.Namespace) -> None:
    email = args.email.lower()
    get_mailbox_id(email)

    updates = [f"active={1 if args.active else 0}"]

    if args.unlimited_quota:
        updates.append("quota_bytes=NULL")
    elif args.quota_bytes is not None:
        updates.append(f"quota_bytes={args.quota_bytes}")

    updates.append("updated_at=CURRENT_TIMESTAMP")

    mysql(
        "UPDATE mailboxes "
        f"SET {', '.join(updates)} "
        f"WHERE email='{sql_quote(email)}'"
    )
    print(f"mailbox updated: {email}")


def cmd_mailbox_del(args: argparse.Namespace) -> None:
    email = args.email.lower()
    mailbox_id = get_mailbox_id(email)
    mysql(f"DELETE FROM sender_acl WHERE mailbox_id={mailbox_id}")
    mysql(f"DELETE FROM mailboxes WHERE id={mailbox_id}")
    if args.purge_files:
        purge_maildir(email)
    else:
        archive_maildir(email)
    print(f"mailbox removed: {email}")


def cmd_alias_list(args: argparse.Namespace) -> None:
    where = ""
    if args.domain:
        where = f" WHERE d.name='{sql_quote(args.domain.lower())}'"
    query = (
        "SELECT a.id, a.source_email, a.destination, a.active, d.name "
        "FROM aliases a JOIN domains d ON d.id = a.domain_id"
        f"{where} ORDER BY d.name, a.source_email"
    )
    print(mysql(query, raw=True), end="")


def cmd_alias_add(args: argparse.Namespace) -> None:
    source = args.source.lower()
    destination = args.destination.lower()
    local, domain = split_email(source)
    domain_id = get_domain_id(domain)
    mysql(
        "INSERT INTO aliases (domain_id, source_local_part, source_email, destination, active) VALUES ("
        f"{domain_id}, '{sql_quote(local)}', '{sql_quote(source)}', '{sql_quote(destination)}', 1) "
        "ON DUPLICATE KEY UPDATE destination=VALUES(destination), active=1, updated_at=CURRENT_TIMESTAMP"
    )
    if args.allow_send:
        mailbox_id = get_mailbox_id(args.allow_send.lower())
        mysql(
            "INSERT INTO sender_acl (mailbox_id, allowed_email, active) VALUES ("
            f"{mailbox_id}, '{sql_quote(source)}', 1) "
            "ON DUPLICATE KEY UPDATE active=1, updated_at=CURRENT_TIMESTAMP"
        )
        print(f"alias ready with sender permission: {source} -> {destination} (send-as {args.allow_send.lower()})")
        return
    print(f"alias ready: {source} -> {destination}")


def cmd_alias_del(args: argparse.Namespace) -> None:
    source = args.source.lower()
    mysql(f"DELETE FROM aliases WHERE source_email='{sql_quote(source)}'")
    print(f"alias removed: {source}")


def cmd_sender_list(args: argparse.Namespace) -> None:
    mailbox_id = get_mailbox_id(args.email.lower())
    print(
        mysql(
            "SELECT sa.id, sa.allowed_email, sa.active "
            f"FROM sender_acl sa WHERE sa.mailbox_id={mailbox_id} ORDER BY sa.allowed_email",
            raw=True,
        ),
        end="",
    )


def cmd_sender_add(args: argparse.Namespace) -> None:
    mailbox_email = args.mailbox.lower()
    allowed_email = args.allowed.lower()
    mailbox_id = get_mailbox_id(mailbox_email)
    mysql(
        "INSERT INTO sender_acl (mailbox_id, allowed_email, active) VALUES ("
        f"{mailbox_id}, '{sql_quote(allowed_email)}', 1) "
        "ON DUPLICATE KEY UPDATE active=1, updated_at=CURRENT_TIMESTAMP"
    )
    print(f"sender permission added: {mailbox_email} -> {allowed_email}")


def cmd_sender_del(args: argparse.Namespace) -> None:
    mailbox_email = args.mailbox.lower()
    allowed_email = args.allowed.lower()
    mailbox_id = get_mailbox_id(mailbox_email)
    mysql(
        "DELETE FROM sender_acl "
        f"WHERE mailbox_id={mailbox_id} AND allowed_email='{sql_quote(allowed_email)}'"
    )
    print(f"sender permission removed: {mailbox_email} -> {allowed_email}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="mailadmin",
        description="Manage virtual mail domains, mailboxes, aliases and sender permissions on five.",
    )
    sub = parser.add_subparsers(dest="entity", required=True)

    domain = sub.add_parser("domain", help="manage domains")
    domain_sub = domain.add_subparsers(dest="action", required=True)
    domain_sub.add_parser("list", help="list domains").set_defaults(func=cmd_domain_list)
    domain_add = domain_sub.add_parser("add", help="add or reactivate a domain")
    domain_add.add_argument("domain")
    domain_add.set_defaults(func=cmd_domain_add)
    domain_del = domain_sub.add_parser("del", help="remove a domain without mailboxes or aliases")
    domain_del.add_argument("domain")
    domain_del.add_argument("--purge-dir", action="store_true", help="remove the domain directory if empty")
    domain_del.set_defaults(func=cmd_domain_del)

    mailbox = sub.add_parser("mailbox", help="manage mailboxes")
    mailbox_sub = mailbox.add_subparsers(dest="action", required=True)
    mailbox_list = mailbox_sub.add_parser("list", help="list mailboxes")
    mailbox_list.add_argument("--domain")
    mailbox_list.set_defaults(func=cmd_mailbox_list)
    mailbox_add = mailbox_sub.add_parser("add", help="add or reactivate a mailbox")
    mailbox_add.add_argument("email")
    mailbox_add.add_argument("--password", required=True)
    mailbox_add.add_argument("--quota-bytes", type=int)
    mailbox_add.set_defaults(func=cmd_mailbox_add)
    mailbox_update = mailbox_sub.add_parser("update", help="update mailbox settings")
    mailbox_update.add_argument("email")
    mailbox_update_state = mailbox_update.add_mutually_exclusive_group(required=True)
    mailbox_update_state.add_argument("--active", action="store_true")
    mailbox_update_state.add_argument("--inactive", action="store_true")
    mailbox_update_quota = mailbox_update.add_mutually_exclusive_group()
    mailbox_update_quota.add_argument("--quota-bytes", type=int)
    mailbox_update_quota.add_argument("--unlimited-quota", action="store_true")
    mailbox_update.set_defaults(func=cmd_mailbox_update)
    mailbox_passwd = mailbox_sub.add_parser("passwd", help="change mailbox password")
    mailbox_passwd.add_argument("email")
    mailbox_passwd.add_argument("--password", required=True)
    mailbox_passwd.set_defaults(func=cmd_mailbox_passwd)
    mailbox_del = mailbox_sub.add_parser("del", help="remove a mailbox")
    mailbox_del.add_argument("email")
    mailbox_del.add_argument("--purge-files", action="store_true", help="delete mailbox files instead of archiving them")
    mailbox_del.set_defaults(func=cmd_mailbox_del)

    alias = sub.add_parser("alias", help="manage aliases")
    alias_sub = alias.add_subparsers(dest="action", required=True)
    alias_list = alias_sub.add_parser("list", help="list aliases")
    alias_list.add_argument("--domain")
    alias_list.set_defaults(func=cmd_alias_list)
    alias_add = alias_sub.add_parser("add", help="add or reactivate an alias")
    alias_add.add_argument("source")
    alias_add.add_argument("destination")
    alias_add.add_argument(
        "--allow-send",
        metavar="MAILBOX",
        help="also allow the given mailbox to send as the alias address",
    )
    alias_add.set_defaults(func=cmd_alias_add)
    alias_del = alias_sub.add_parser("del", help="remove an alias")
    alias_del.add_argument("source")
    alias_del.set_defaults(func=cmd_alias_del)

    sender = sub.add_parser("sender-allow", help="manage additional allowed sender identities")
    sender_sub = sender.add_subparsers(dest="action", required=True)
    sender_list = sender_sub.add_parser("list", help="list sender permissions for a mailbox")
    sender_list.add_argument("email")
    sender_list.set_defaults(func=cmd_sender_list)
    sender_add = sender_sub.add_parser("add", help="allow a mailbox to send as an extra address")
    sender_add.add_argument("mailbox")
    sender_add.add_argument("allowed")
    sender_add.set_defaults(func=cmd_sender_add)
    sender_del = sender_sub.add_parser("del", help="remove an extra sender permission")
    sender_del.add_argument("mailbox")
    sender_del.add_argument("allowed")
    sender_del.set_defaults(func=cmd_sender_del)

    return parser


def main() -> None:
    require_root()
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
